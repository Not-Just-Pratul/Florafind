-- Name: garden_plants Allow users to delete their own garden plants; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow users to delete their own garden plants" ON public.garden_plants FOR DELETE USING ((auth.uid() = user_id));


--
-- Name: garden_plants Allow users to insert their own garden plants; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow users to insert their own garden plants" ON public.garden_plants FOR INSERT WITH CHECK ((auth.uid() = user_id));


--
-- Name: garden_plants Allow users to select their own garden plants; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow users to select their own garden plants" ON public.garden_plants FOR SELECT USING ((auth.uid() = user_id));


--
-- Name: garden_plants Allow users to update their own garden plants; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow users to update their own garden plants" ON public.garden_plants FOR UPDATE USING ((auth.uid() = user_id));


--
-- Name: garden_plants Users can delete their own plants; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can delete their own plants" ON public.garden_plants FOR DELETE USING ((auth.uid() = user_id));


--
-- Name: garden_plants Users can insert their own plants; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can insert their own plants" ON public.garden_plants FOR INSERT WITH CHECK ((auth.uid() = user_id));


--
-- Name: garden_plants Users can update their own plants; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can update their own plants" ON public.garden_plants FOR UPDATE USING ((auth.uid() = user_id));


