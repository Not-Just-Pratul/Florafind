--
-- Name: objects Allow authenticated users to upload plant images; Type: POLICY; Schema: storage; Owner: supabase_storage_admin
--

CREATE POLICY "Allow authenticated users to upload plant images" ON storage.objects FOR INSERT WITH CHECK (((bucket_id = 'plant_images'::text) AND (auth.role() = 'authenticated'::text)));


--
-- Name: objects Allow public read access to plant images; Type: POLICY; Schema: storage; Owner: supabase_storage_admin
--

CREATE POLICY "Allow public read access to plant images" ON storage.objects FOR SELECT USING ((bucket_id = 'plant_images'::text));


--
-- Name: objects Allow users to delete their own plant images; Type: POLICY; Schema: storage; Owner: supabase_storage_admin
--

CREATE POLICY "Allow users to delete their own plant images" ON storage.objects FOR DELETE USING (((bucket_id = 'plant_images'::text) AND (auth.uid() = owner)));


